class Solution {
    public boolean isPalindrome(String s) {
        String reversed = "";
        s = s.replaceAll("[^A-Za-z0-9]" , "");
        s=s.toLowerCase();

        for(int i=s.length()-1;i>=0;i--){
            reversed += s.charAt(i);
        }
        if(s.equals(reversed)){
            return true;
        }
        return false;
    }
}
